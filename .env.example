# Django 核心配置
# 复制此文件为 .env 并填入真实值

# 生产环境必须设置为 False
DJANGO_DEBUG=True

# 生产环境必须替换为强随机密钥
# 生成方式: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key

# 生产环境必须设置实际域名/IP，多个用逗号分隔
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# 数据库配置 (SQLite 默认，生产环境使用 PostgreSQL/MySQL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=library_db
# DB_USER=library_user
# DB_PASSWORD=db_password
# DB_HOST=localhost
# DB_PORT=5432

# init_data.py 种子数据用户密码
# OWNER_PASSWORD=your_strong_owner_password
# ADMIN_PASSWORD=your_strong_admin_password
# READER_PASSWORD=your_reader_password
# TEST_PASSWORD=your_test_accounts_password

# GitHub API 推送配置 (用于 push_via_api.py)
# 从 https://github.com/settings/tokens 生成 Personal Access Token
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=qianmo-1
GITHUB_REPO=ml_library
GITHUB_BRANCH=main
